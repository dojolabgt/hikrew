# ==============================================
# Application Configuration
# ==============================================
NODE_ENV=development
PORT=4000
BODY_PARSER_LIMIT=10mb  # Maximum size for JSON/URL-encoded payloads

# ==============================================
# Database Configuration
# ==============================================
# Postgres Container Settings
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=dashboard_db

# Backend App Connection (Should match above)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=admin
DATABASE_PASSWORD=admin
DATABASE_NAME=dashboard_db

# ==============================================
# Authentication & Security
# ==============================================
JWT_SECRET=supersecretkey
JWT_REFRESH_SECRET=supersecretrefreshkey
BCRYPT_SALT_ROUNDS=10

# CORS Configuration (accepts multiple origins separated by comma)
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ==============================================
# Frontend Configuration
# ==============================================
# API & Backend URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_IMAGE_BACKEND_URL=http://backend:4000

# Application URLs
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
FRONTEND_PUBLIC_URL=http://localhost:3001     # Public landing page

# Branding Defaults (optional - fallback to app settings)
NEXT_PUBLIC_APP_NAME=NexStack Starter
NEXT_PUBLIC_OWNER_NAME=NEXSTACK
NEXT_PUBLIC_OWNER_INITIALS=NS
NEXT_PUBLIC_OWNER_TITLE=Nexstack

# ==============================================
# File Storage & Uploads
# ==============================================
STORAGE_TYPE=local
UPLOAD_MAX_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,gif

# Future S3 Configuration (uncomment when migrating to S3)
# AWS_REGION=us-east-1
# AWS_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ==============================================
# Email Configuration
# ==============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Your Name <your-email@example.com>"

# ==============================================
# Database Seeding
# ==============================================
SEED_ADMIN_PASSWORD=admin123
SEED_CLIENT_PASSWORD=client123
SEED_TEAM_PASSWORD=team123
