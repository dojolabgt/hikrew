# ==============================================
# Application Configuration
# ==============================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
FRONTEND_PUBLIC_URL=http://localhost:3001
# Maximum size for JSON/URL-encoded payloads
BODY_PARSER_LIMIT=10mb

# ==============================================
# Database Configuration
# ==============================================
# Postgres Container Settings
POSTGRES_USER=blend_dev
POSTGRES_PASSWORD=blend123
POSTGRES_DB=blendev_db

# Backend App Connection (Should match above)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=blend_dev
DATABASE_PASSWORD=blend123
DATABASE_NAME=blendev_db

# ==============================================
# Authentication & Security
# ==============================================
JWT_SECRET=supersecretkey
JWT_REFRESH_SECRET=supersecretrefreshkey
BCRYPT_SALT_ROUNDS=10

# CORS Configuration (accepts multiple origins separated by comma - see line 6)

# ==============================================
# Frontend Configuration
# ==============================================
# API & Backend URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_IMAGE_BACKEND_URL=/backend-images

# Application URLs
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
# FRONTEND_PUBLIC_URL already defined above (line 7)

# Branding Defaults (optional - fallback to app settings)
# NEXT_PUBLIC_APP_NAME=NexStack Starter
# NEXT_PUBLIC_OWNER_NAME=NEXSTACK
# NEXT_PUBLIC_OWNER_INITIALS=NS
# NEXT_PUBLIC_OWNER_TITLE=Nexstack

# ==============================================
# File Storage & Uploads
# ==============================================
STORAGE_TYPE=local
UPLOAD_MAX_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp,gif

# Future S3 Configuration (uncomment when migrating to S3)
# AWS_REGION=us-east-1
# AWS_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ==============================================
# Email Configuration
# ==============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=ejemplo@correo.com
MAIL_PASSWORD=secretkey
MAIL_FROM="Name <ejemplo@correo.com>"

# ==============================================
# Database Seeding
# ==============================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_FREELANCER_EMAIL=freelancer@example.com
SEED_FREELANCER_PASSWORD=freelancer123

